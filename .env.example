# 공공데이터포털 (data.go.kr) — 금융위 파생상품시세정보 API
# https://www.data.go.kr/data/15094802/openapi.do 에서 신청
# 이용허락범위 제한 없음 (무료, 재배포 가능)
DATA_GO_KR_API_KEY=your_data_go_kr_service_key_here

# Night Session (configurable — KRX may change)
NIGHT_SESSION_OPEN=18:00
NIGHT_SESSION_CLOSE=05:00

# Application
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
