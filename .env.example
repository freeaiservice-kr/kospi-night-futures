# 한국투자증권 API
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=00000000-03

# API URLs
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_WS_URL=ws://ops.koreainvestment.com:21000

# Night Session (configurable — KRX may change)
NIGHT_SESSION_OPEN=18:00
NIGHT_SESSION_CLOSE=05:00

# Futures Symbol
# Format: prefix + month-letter (F=Jan, G=Feb, H=Mar, J=Apr, K=May, M=Jun, N=Jul, Q=Aug, U=Sep, V=Oct, X=Nov, Z=Dec) + year-digits
# KRX KOSPI200 futures code: 101 prefix + expiry
# Example: 101V12 = KOSPI200 futures, Oct cycle, 2012? Check KIS docs for exact format
# ⚠️ Contracts expire quarterly — update or enable auto-detect
FUTURES_SYMBOL=auto

# Application
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
